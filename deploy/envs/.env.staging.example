# td-sync STAGING environment
# Copy to .env.staging and fill in values
# Run: ./deploy.sh staging

# === Required: Deployment Target ===
DEPLOY_HOST=staging.example.com
DEPLOY_USER=deploy
DEPLOY_PATH=/opt/td-sync

# === Required: Server URL ===
SYNC_BASE_URL=https://staging-sync.example.com

# === Server Config ===
SYNC_LISTEN_PORT=8080
SYNC_ALLOW_SIGNUP=true
SYNC_SHUTDOWN_TIMEOUT=30s
SYNC_LOG_FORMAT=json
SYNC_LOG_LEVEL=info

# === Email Provider (required for auth) ===
SYNC_EMAIL_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM=login@opentangle.com
CLOUDFLARE_EMAIL_FROM_NAME=td-watch
CLOUDFLARE_EMAIL_REPLY_TO=haplab@vorwaller.net
SYNC_EMAIL_BASE_URL=https://sync-staging.haplab.com
SYNC_AUTH_WEB_CALLBACK_URL=https://watch-staging.haplab.com/home/login/complete

# === Rate Limits (production-like) ===
SYNC_RATE_LIMIT_AUTH=10
SYNC_RATE_LIMIT_PUSH=60
SYNC_RATE_LIMIT_PULL=120
SYNC_RATE_LIMIT_OTHER=300

# === Litestream S3 (optional for staging) ===
# Uncomment and fill in to enable S3 backup
# LITESTREAM_S3_BUCKET=td-staging-backups
# LITESTREAM_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
